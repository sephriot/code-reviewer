# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# LLM Configuration
# Options: CLAUDE or CODEX
REVIEW_MODEL=CLAUDE
PROMPT_FILE=prompts/review_prompt.txt
# Optional: separate output format prompt (appended to the review prompt)
# OUTPUT_FORMAT_FILE=prompts/output_format.md

# Application Settings
POLL_INTERVAL=60
REVIEW_TIMEOUT=600
# Set to 0 to disable the automated review timeout
LOG_LEVEL=INFO

# Sound Notifications
# You can use either:
#   - Audio file path: sounds/notification.wav
#   - Text-to-speech: say:Text to speak OR espeak:Text to speak
# Available placeholders for TTS: {repo}, {pr_number}, {author}, {title}
SOUND_ENABLED=true
# SOUND_FILE=sounds/review_required.mp3
# SOUND_FILE="say:New review request for PR {title} in {repo} authored by {author}"

# Timeout Notification for Review Failures
TIMEOUT_SOUND_ENABLED=true
# TIMEOUT_SOUND_FILE=sounds/review_timeout.mp3
# TIMEOUT_SOUND_FILE="say:Review for PR {title} in {repo} timed out"

# PR Approval Sound Notifications
APPROVAL_SOUND_ENABLED=true
# APPROVAL_SOUND_FILE=sounds/pr_approved.mp3
# APPROVAL_SOUND_FILE="say:PR {title} in {repo} has been approved"

# Review Started Sound Notifications
REVIEW_STARTED_SOUND_ENABLED=true
# REVIEW_STARTED_SOUND_FILE=sounds/review_started.mp3
# REVIEW_STARTED_SOUND_FILE="say:Review started for PR {title} in {repo}"

# Outdated Pending Approval Sound Notifications
MERGED_OR_CLOSED_SOUND_ENABLED=true
# MERGED_OR_CLOSED_SOUND_FILE=sounds/pr_merged_closed.mp3
# MERGED_OR_CLOSED_SOUND_FILE="say:PR {title} in {repo} has been merged or closed"
# Legacy: OUTDATED_SOUND_ENABLED/OUTDATED_SOUND_FILE remain supported

# Own PRs Monitoring
OWN_PR_ENABLED=false
# Own PR Sound Notifications
OWN_PR_READY_SOUND_ENABLED=true
# OWN_PR_READY_SOUND_FILE=sounds/pr_ready.mp3
# OWN_PR_READY_SOUND_FILE="say:Your own PR {title} in {repo} is ready for merge!"
OWN_PR_NEEDS_ATTENTION_SOUND_ENABLED=true
# OWN_PR_NEEDS_ATTENTION_SOUND_FILE=sounds/pr_needs_attention.mp3
# OWN_PR_NEEDS_ATTENTION_SOUND_FILE="say:Your own PR {title} in {repo} needs attention!"

# Dry Run Mode (log actions instead of performing them)
DRY_RUN=false

# Database settings
DATABASE_PATH=data/reviews.db

# Optional: Specific repositories to monitor (comma-separated, format: owner/repo)
# REPOSITORIES=owner/repo1,owner/repo2

# Optional: Specific PR authors to monitor (comma-separated, GitHub usernames)
# PR_AUTHORS=username1,username2

# Web UI Configuration
WEB_ENABLED=false
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Show Claude's thinking process in logs
SHOW_THINKING=false

# Atlas Knowledge Injection (requires Atlas MCP configured globally)
ATLAS_ENABLED=false
