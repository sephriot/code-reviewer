# Go v2 control plane. Copy to .env.v2, then adjust values as needed.
# Legacy .env settings do not configure reviewd. run.sh still imports it only
# so its GITHUB_TOKEN can be referenced by this file.

REVIEWD_DATABASE_PATH=data/control-plane.db
REVIEWD_LISTEN_ADDRESS=127.0.0.1:8080
REVIEWD_MIGRATION_MODE=apply

# Safe default. `true` requires read-only reconciliation configuration plus an
# explicit guarded dispatch request.
REVIEWD_PUBLICATION_MODE_ENABLED=false

# Optional read-only GitHub observation. GITHUB_TOKEN itself stays in .env or
# shell environment; this value is only its variable name.
REVIEWD_SHADOW_RECONCILE_ENABLED=false
REVIEWD_GITHUB_CONNECTION_ID=github-local
REVIEWD_GITHUB_API_BASE_URL=https://api.github.com
REVIEWD_GITHUB_TOKEN_ENVIRONMENT=GITHUB_TOKEN
REVIEWD_SHADOW_RECONCILE_INTERVAL=5m

# Optional trusted local review engine. Command must be JSON argv. Keep false
# until profile + policy are configured. Engine receives review bundle on stdin,
# must return one v1 assessment JSON document on stdout, and gets no token.
REVIEWD_REVIEW_EXECUTION_ENABLED=false
REVIEWD_REVIEW_ENGINE_AUTH_ROOT=.reviewd/engine-auth
# REVIEWD_REVIEW_ENGINE_PROVIDER=codex # claude | codex | agent
# Provider mode requires no REVIEWD_REVIEW_ENGINE_ARGV.
# REVIEWD_REVIEW_ENGINE_ARGV='["/absolute/path/to/review-engine","--json"]'
#
# Example after installing/testing your own trusted adapter:
# REVIEWD_REVIEW_EXECUTION_ENABLED=true
# REVIEWD_REVIEW_ENGINE_ARGV='["/usr/local/bin/review-engine","--input","-"]'
#
# Restart reviewd after changing this file: stop ./run.sh with Ctrl-C, then run
# ./run.sh again. Confirm "Review runtime enabled" in Control Desk settings.

# Optional local signed webhook ingress.
REVIEWD_GITHUB_WEBHOOK_ENABLED=false
# REVIEWD_GITHUB_WEBHOOK_SECRET_ENVIRONMENT=GITHUB_WEBHOOK_SECRET
